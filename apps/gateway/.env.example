# Signing: HS256 (default) | RS256 | EdDSA
ACR_SIGNING_ALGORITHM=HS256
ACR_SIGNING_SECRET=dev-secret-change-in-production-32b-minimum
# RS256 / EdDSA (production) — issuer holds private key, runtimes verify with public key only
# ACR_SIGNING_ALGORITHM=RS256
# ACR_SIGNING_PRIVATE_KEY_PATH=./keys/private.pem
# ACR_SIGNING_PUBLIC_KEY_PATH=./keys/public.pem
ACR_ISSUER=acr-runtime
PORT=3000

# Admin auth for grant/delegate (RFC-0005). Omit only for local dev.
ACR_ADMIN_API_KEY=dev-admin-key-change-in-production-32b-min
# Or comma-separated for rotation:
# ACR_ADMIN_API_KEYS=key-a,key-b

# Adapter mode: stub | live | auto (default auto — live when tokens are set)
ACR_ADAPTER_MODE=auto

# Gmail — OAuth access token with https://www.googleapis.com/auth/gmail.send
GMAIL_ACCESS_TOKEN=
GMAIL_USER_ID=me
GMAIL_FROM=

# Slack — Bot token with chat:write scope
SLACK_BOT_TOKEN=

# Persistent stores (optional — omit for in-memory)
ACR_AUDIT_PATH=./data/audit.jsonl
ACR_APPROVAL_PATH=./data/approvals.json

# Tamper-evident audit hash chain (optional — default off)
# ACR_AUDIT_CHAIN_ENABLED=true
# ACR_AUDIT_CHAIN_SECRET=audit-hmac-secret-min-32-characters-required

# Distributed consumption (optional — for multi-instance gateways; requires `redis` npm package)
# ACR_REDIS_URL=redis://localhost:6379
# ACR_CONSUMPTION_MODE=redis
# ACR_REDIS_KEY_PREFIX=acr:consume
# ACR_CONSUMPTION_TTL_SEC=86400

# Dashboard UI (served at /dashboard/ when built)
# ACR_DASHBOARD_ENABLED=false
# ACR_OPA_URL=http://127.0.0.1:8181
# ACR_OPA_BUNDLE_PATH=../../packages/policy-engine/examples/opa/acr.rego
# ACR_OPA_MODE=enforce
# ACR_OPA_DECISION_PATH=acr/decision
# ACR_OPA_TIMEOUT_MS=3000

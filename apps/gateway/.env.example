ACR_SIGNING_SECRET=dev-secret-change-in-production-32b-minimum
ACR_ISSUER=acr-runtime
PORT=3000

# Adapter mode: stub | live | auto (default auto — live when tokens are set)
ACR_ADAPTER_MODE=auto

# Gmail — OAuth access token with https://www.googleapis.com/auth/gmail.send
GMAIL_ACCESS_TOKEN=
GMAIL_USER_ID=me
GMAIL_FROM=

# Slack — Bot token with chat:write scope
SLACK_BOT_TOKEN=

# Persistent stores (optional — omit for in-memory)
ACR_AUDIT_PATH=./data/audit.jsonl
ACR_APPROVAL_PATH=./data/approvals.json

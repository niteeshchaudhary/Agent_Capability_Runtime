{
  "name": "@acr/capability-token",
  "version": "0.1.0",
  "description": "Signed capability JWT generation and validation for Agent Capability Runtime",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-capability-runtime/Agent_Capability_Runtime.git",
    "directory": "packages/capability-token"
  },
  "homepage": "https://github.com/agent-capability-runtime/Agent_Capability_Runtime#readme",
  "bugs": {
    "url": "https://github.com/agent-capability-runtime/Agent_Capability_Runtime/issues"
  },
  "keywords": ["ai-agents", "authorization", "jwt", "capability-token", "zero-trust"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "example": "tsx examples/grant-and-validate.ts"
  },
  "dependencies": {
    "jose": "^6.0.11",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}

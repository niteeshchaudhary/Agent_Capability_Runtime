{
  "name": "@acr/policy-engine",
  "version": "0.1.0",
  "description": "Constraint evaluation and runtime decisions for Agent Capability Runtime",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./opa": {
      "types": "./dist/opa/index.d.ts",
      "import": "./dist/opa/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-capability-runtime/Agent_Capability_Runtime.git",
    "directory": "packages/policy-engine"
  },
  "homepage": "https://github.com/agent-capability-runtime/Agent_Capability_Runtime#readme",
  "bugs": {
    "url": "https://github.com/agent-capability-runtime/Agent_Capability_Runtime/issues"
  },
  "keywords": ["ai-agents", "policy", "authorization", "runtime"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@acr/capability-token": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}

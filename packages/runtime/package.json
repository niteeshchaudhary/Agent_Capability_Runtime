{
  "name": "@acr/runtime",
  "version": "0.1.0",
  "description": "Runtime gateway and policy enforcement for Agent Capability Runtime",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-capability-runtime/Agent_Capability_Runtime.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/agent-capability-runtime/Agent_Capability_Runtime#readme",
  "bugs": {
    "url": "https://github.com/agent-capability-runtime/Agent_Capability_Runtime/issues"
  },
  "keywords": ["ai-agents", "runtime", "authorization", "governance", "policy"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@acr/adapters": "workspace:*",
    "@acr/audit": "workspace:*",
    "@acr/capability-token": "workspace:*",
    "@acr/policy-engine": "workspace:*"
  },
  "peerDependencies": {
    "redis": "^4.7.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "redis": "^4.7.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}

{
  "name": "@acr/runtime",
  "version": "0.1.0",
  "description": "Runtime gateway and policy enforcement for Agent Capability Runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@acr/adapters": "workspace:*",
    "@acr/audit": "workspace:*",
    "@acr/capability-token": "workspace:*",
    "@acr/policy-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
